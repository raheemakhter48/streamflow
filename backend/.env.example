NODE_ENV=production
PORT=7860

# Existing Supabase/auth variables go here.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=

# Separate admin console login. When ADMIN_PANEL_PASSWORD is set,
# /api/admin/* requires this panel session instead of normal user access.
ADMIN_PANEL_EMAIL=
ADMIN_PANEL_PASSWORD=

# TMDB catalog (prefer the Read Access Token; API key is also supported)
TMDB_API_TOKEN=
TMDB_API_KEY=
TMDB_CACHE_TTL_MS=300000
TMDB_CACHE_MAX_ENTRIES=500

# Smart Global Routing
# Supported forward-proxy schemes depend on proxy-agent (http, https, socks4, socks5).
# Only add regions for which you have a real proxy/VPN exit.
STREAM_PROXY_REGIONS=us,uk,in,eu
STREAM_PROXY_US_URL=
STREAM_PROXY_UK_URL=
STREAM_PROXY_IN_URL=
STREAM_PROXY_EU_URL=
STREAM_PROXY_MANIFEST_TIMEOUT_MS=12000
STREAM_PROXY_SEGMENT_TIMEOUT_MS=20000
